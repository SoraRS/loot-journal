{
  "display_name": "Minecraft Java",
  "description": "Mimics the look and feel of Minecraft: Java Edition interfaces.",
  "layout": {
    "screen_margin": 1,
    "padding_left": 6,
    "padding_right": 6,
    "padding_top": 3,
    "padding_bottom": 3
  },
  "bindings": [
    {
      "priority": 0,
      "style": "loot_journal:java/default",
      "match": { "always": true }
    },
    {
      "priority": 10,
      "style": "loot_journal:java/epic",
      "match": { "rarity": "epic" }
    },
    {
      "priority": 20,
      "style": "loot_journal:java/xp",
      "match": { "is_xp": true }
    }
  ],
  "variables": [
    {
      "key": "name_color",
      "display_name": "config.loot_journal.theme.name_color",
      "description": "config.loot_journal.theme.name_color.desc",
      "type": "color",
      "default": "#FFFFFFFF"
    },
    {
      "key": "pickup_count_color",
      "display_name": "config.loot_journal.theme.pickup_count_color",
      "description": "config.loot_journal.theme.pickup_count_color.desc",
      "type": "color",
      "default": "#FFAAAAAA"
    },
    {
      "key": "total_count_color",
      "display_name": "config.loot_journal.theme.total_count_color",
      "description": "config.loot_journal.theme.total_count_color.desc",
      "type": "color",
      "default": "#FF555555"
    }
  ]
}