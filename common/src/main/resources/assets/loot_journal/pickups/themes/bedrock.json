{
  "display_name": "Minecraft Bedrock",
  "description": "Inspired by the clean and modern UI of Minecraft: Bedrock Edition.",
  "layout": {
    "screen_margin": 1,
    "padding_left": 6,
    "padding_right": 6,
    "padding_top": 2,
    "padding_bottom": 4
  },
  "bindings": [
    {
      "priority": 0,
      "style": "loot_journal:bedrock/default",
      "match": { "always": true }
    },
    {
      "priority": 10,
      "style": "loot_journal:bedrock/epic",
      "match": { "rarity": "epic" }
    },
    {
      "priority": 20,
      "style": "loot_journal:bedrock/xp",
      "match": { "is_xp": true }
    }
  ],
  "variables": [
    {
      "key": "name_color",
      "display_name": "config.loot_journal.theme.name_color",
      "description": "config.loot_journal.theme.name_color.desc",
      "type": "color",
      "default": "#FF1B1B1E"
    },
    {
      "key": "pickup_count_color",
      "display_name": "config.loot_journal.theme.pickup_count_color",
      "description": "config.loot_journal.theme.pickup_count_color.desc",
      "type": "color",
      "default": "#FFBC6B00"
    },
    {
      "key": "total_count_color",
      "display_name": "config.loot_journal.theme.total_count_color",
      "description": "config.loot_journal.theme.total_count_color.desc",
      "type": "color",
      "default": "#FF555555"
    }
  ]
}