{
  "display_name": "Tooltip",
  "description": "Styled to match Minecraft tooltips, with a familiar bordered background.",
  "layout": {
    "screen_margin": 1,
    "padding_left": 6,
    "padding_right": 6,
    "padding_top": 2,
    "padding_bottom": 2
  },
  "bindings": [
    {
      "priority": 0,
      "style": "loot_journal:tooltip/default",
      "match": { "always": true }
    },
    {
      "priority": 10,
      "style": "loot_journal:tooltip/epic",
      "match": { "rarity": "epic" }
    },
    {
      "priority": 20,
      "style": "loot_journal:tooltip/xp",
      "match": { "is_xp": true }
    }
  ],
  "variables": [
    {
      "key": "name_color",
      "display_name": "config.loot_journal.theme.name_color",
      "description": "config.loot_journal.theme.name_color.desc",
      "type": "loot_journal:color",
      "default": "#FFFFFFFF"
    },
    {
      "key": "pickup_count_color",
      "display_name": "config.loot_journal.theme.pickup_count_color",
      "description": "config.loot_journal.theme.pickup_count_color.desc",
      "type": "loot_journal:color",
      "default": "#FFAAAAAA"
    },
    {
      "key": "total_count_color",
      "display_name": "config.loot_journal.theme.total_count_color",
      "description": "config.loot_journal.theme.total_count_color.desc",
      "type": "loot_journal:color",
      "default": "#FF555555"
    }
  ]
}