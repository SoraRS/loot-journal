{
  "display_name": "Minimal",
  "description": "A clean and unobtrusive style with flat, semi-transparent backgrounds.",
  "layout": {
    "screen_margin": 1,
    "padding_left": 4,
    "padding_right": 8,
    "padding_top": 0,
    "padding_bottom": 0
  },
  "bindings": [
    {
      "priority": 0,
      "style": "loot_journal:minimal/default",
      "match": { "always": true }
    },
    {
      "priority": 10,
      "style": "loot_journal:minimal/epic",
      "match": { "rarity": "epic" }
    },
    {
      "priority": 20,
      "style": "loot_journal:minimal/xp",
      "match": { "is_xp": true }
    }
  ],
  "variables": [
    {
      "key": "panel_color",
      "display_name": "config.loot_journal.theme.panel_color",
      "description": "config.loot_journal.theme.panel_color.desc",
      "type": "loot_journal:color",
      "default": "#80000000"
    },
    {
      "key": "name_color",
      "display_name": "config.loot_journal.theme.name_color",
      "description": "config.loot_journal.theme.name_color.desc",
      "type": "loot_journal:color",
      "default": "#FFFFFFFF"
    },
    {
      "key": "pickup_count_color",
      "display_name": "config.loot_journal.theme.pickup_count_color",
      "description": "config.loot_journal.theme.pickup_count_color.desc",
      "type": "loot_journal:color",
      "default": "#FFAAAAAA"
    },
    {
      "key": "total_count_color",
      "display_name": "config.loot_journal.theme.total_count_color",
      "description": "config.loot_journal.theme.total_count_color.desc",
      "type": "loot_journal:color",
      "default": "#FFAAAAAA"
    }
  ]
}