{
  "display_name": "Minecraft Dungeons",
  "description": "Based on the bold and stylized visuals of Minecraft Dungeons.",
  "layout": {
    "screen_margin": 1,
    "padding_left": 6,
    "padding_right": 6,
    "padding_top": 3,
    "padding_bottom": 3
  },
  "bindings": [
    {
      "priority": 0,
      "style": "loot_journal:dungeons/default",
      "match": { "always": true }
    },
    {
      "priority": 10,
      "style": "loot_journal:dungeons/epic",
      "match": { "rarity": "epic" }
    },
    {
      "priority": 20,
      "style": "loot_journal:dungeons/xp",
      "match": { "is_xp": true }
    }
  ],
  "variables": [
    {
      "key": "name_color",
      "display_name": "config.loot_journal.theme.name_color",
      "description": "config.loot_journal.theme.name_color.desc",
      "type": "color",
      "default": "#FFFDFDFD"
    },
    {
      "key": "pickup_count_color",
      "display_name": "config.loot_journal.theme.pickup_count_color",
      "description": "config.loot_journal.theme.pickup_count_color.desc",
      "type": "color",
      "default": "#FF7DCA76"
    },
    {
      "key": "total_count_color",
      "display_name": "config.loot_journal.theme.total_count_color",
      "description": "config.loot_journal.theme.total_count_color.desc",
      "type": "color",
      "default": "#FFFBCF77"
    }
  ]
}