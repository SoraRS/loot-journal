{
  "panel": {
    "type": "loot_journal:fill",
    "color": "var(panel_color)"
  },
  "banner": {
    "type": "loot_journal:none"
  },
  "icon": {
    "type": "loot_journal:simple",
    "x_offset": 0,
    "y_offset": 0,
    "padding_left": 0,
    "padding_right": 0,
    "effect": {
      "type": "loot_journal:ray_glow",
      "primary_color": "#FF0FA000",
      "secondary_color": "#FFA69F01",
      "scale": 0.5
    }
  },
  "text": {
    "font": "default",
    "name_color": "var(name_color)",
    "pickup_count_color": "var(pickup_count_color)",
    "total_count_color": "var(total_count_color)",
    "drop_shadow": true,
    "ignore_formatting": false
  }
}